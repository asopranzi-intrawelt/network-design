        <mxCell id="vs-list" value="&lt;b&gt;ATTIVI&lt;/b&gt;&#10;• Subnet_nat &#8212; lan1: LAN1_SUBNET → RFC1918_3 (1-to-1 NAT con loopback)&#10;• VPN_UDP_500 &#8212; wan1: WAN_IP udp/500 → WAN_IP (IPsec IKE)&#10;• VPN_UDP_4500 &#8212; wan1: WAN_IP udp/4500 → WAN_IP (IPsec NAT-T)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffbe6;strokeColor=#d6b656;align=left;fontSize=9;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="1410" width="380" height="70" as="geometry" />
        </mxCell>

        <mxCell id="vs-list-off" value="&lt;b&gt;DISATTIVATI (deactivate)&lt;/b&gt;&#10;• DOMV_WEB → DOMV (10.61.20.116)&#10;• NAS_FTP_WEB → NAS-FTP (.167)&#10;• NAS_HERO_SUPPORT → NAS-HERO (.169)&#10;• EGETRAD_WEB → EGETRAD (.5)&#10;• DEMO_SERVER_WEB → DEMO_SERVER (.92)&#10;• OpenVpn udp/1194 → SERVER_OPEN_VPN (.114)&#10;• VPN_auth_LAN2 (wan2) → 10.61.100.2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;align=left;fontSize=9;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="440" y="1410" width="400" height="70" as="geometry" />
