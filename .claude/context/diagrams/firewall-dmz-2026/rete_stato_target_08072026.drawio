        <mxCell id="flow" value="&lt;b&gt;Flusso esposizione web&lt;/b&gt;&lt;br&gt;Internet → WAN_IP_DMZ_WEB&lt;br&gt;(203.0.113.3, alias wan1:2)&lt;br&gt;NAT 80/443 → 10.61.201.10&lt;br&gt;(VM nginx in DMZ)&lt;br&gt;nginx → upstream applicativi&lt;br&gt;(gestione a livello applicativo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#1e8449;align=left;spacing=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="240" height="120" as="geometry" />
        </mxCell>

        <mxCell id="note0807" value="&lt;b&gt;Rev 08/07/2026&lt;/b&gt;&lt;br&gt;Secondo collegamento PT↔P2:&lt;br&gt;trunk 802.1Q con VLAN dati del&lt;br&gt;Piano Terra e VLAN fonia (tagged).&lt;br&gt;ID VLAN da fissare a lavori conclusi&lt;br&gt;(nota PORT-TAGGING). Aperti:&lt;br&gt;NET-008 (VLAN 1 non taggabile sulla&lt;br&gt;dorsale senza perdere il NAS-HERO),&lt;br&gt;TEL-002 (tratto vano ascensore)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#b7950b;align=left;spacing=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="240" height="150" as="geometry" />
