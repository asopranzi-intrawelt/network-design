        <mxCell id="title" value="STATO TARGET — DIAGRAMMA DI RETE (rev 08/07/2026: secondo trunk Piano Terra ↔ Piano 2)" style="text;html=1;fontSize=18;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="780" height="30" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="&lt;b&gt;LEGENDA&lt;/b&gt;&lt;br&gt;━━━ Fibra Ottica&lt;br&gt;━━━ Ethernet (untagged)&lt;br&gt;━━━ Trunk 802.1Q (LAN + VLAN 201)&lt;br&gt;━━━ Trunk 802.1Q PT↔P2 (VLAN dati PT + VLAN fonia)&lt;br&gt;&lt;br&gt;&lt;b&gt;Rimossi:&lt;/b&gt; WAN_TRUNK, LAN2,&lt;br&gt;rotte statiche, router downstream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacing=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="240" height="150" as="geometry" />
        </mxCell>

        <mxCell id="internet" value="INTERNET" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="510" y="60" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="router" value="ROUTER VIANOVA&#10;(balancing a carico ISP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="160" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="firewall" value="FIREWALL ZYXEL USG FLEX 500&#10;WAN1 attiva (203.0.113.5) — WAN2 shutdown&#10;ge4/lan1 = LAN untagged • ge6/dmz (P7) = DMZ untagged&#10;Solo routing L3: nessun tagging VLAN sul firewall" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="430" y="250" width="320" height="80" as="geometry" />
        </mxCell>

        <mxCell id="switch54" value="SWITCH ZYXEL Gigabit 54 porte — Managed 802.1Q (Piano 2)&#10;porta da P4 (lan1): access LAN • porta da P7 (dmz): access VLAN 201&#10;porta verso Proxmox: TRUNK (LAN untagged + VLAN 201 tagged)&#10;Il tagging 802.1Q è eseguito SOLO dagli switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="380" width="380" height="80" as="geometry" />
        </mxCell>

        <mxCell id="proxmox" value="SERVER HP Gen10 — PROXMOX&#10;NIC trunk → vmbr0 VLAN-aware&#10;VM LAN: tag none (10.61.10/20.x)&#10;VM DMZ: tag 201 (10.61.201.x)&#10;nginx reverse proxy: 10.61.201.10&#10;ILO + NIC restanti" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#1e8449;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="430" y="520" width="320" height="110" as="geometry" />
        </mxCell>

        <mxCell id="qnap" value="SWITCH QNAP 10 GbE&#10;NAS INTRA2 (TS-435XeU)&#10;NAS HERO (TS-h1677XU-RP)&#10;NAS INTRA (TS-410U)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="850" y="400" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="sw30" value="SWITCH ZYXEL 30 porte&#10;(Piano Terra)&#10;Workstation utenti + telefoni VoIP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="140" y="400" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="guest" value="Wi-Fi GUEST (zona OPT)&#10;ge7/P8 — 10.61.90.0/24&#10;Solo Internet: deny verso LAN1 e DMZ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="850" y="270" width="220" height="60" as="geometry" />
