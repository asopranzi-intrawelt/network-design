        <mxCell id="sw30" value="SWITCH ZYXEL XGS2220-30HP (Piano Terra) — Nebula managed&#10;Porte 21/23: Persona-A/B/C (SIP-T34W, gia' operativi)&#10;Due porte con telefoni IP: attualmente non visibili" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="340" height="90" as="geometry" />
