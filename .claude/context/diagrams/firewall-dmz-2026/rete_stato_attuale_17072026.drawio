<mxfile host="app.diagrams.net" modified="2026-07-17T10:00:00.000Z" agent="Claude" version="24.0.0">
  <diagram id="attuale-17072026" name="Stato Attuale 17/07/2026 — Dorsale e fonia">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1250" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="STATO ATTUALE — DORSALE PIANO TERRA / PIANO 2 E FONIA (rev 17/07/2026)" style="text;html=1;fontSize=18;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="240" y="15" width="800" height="30" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="&lt;b&gt;LEGENDA&lt;/b&gt;&lt;br&gt;━━━ Fibra Ottica&lt;br&gt;━━━ Ethernet&lt;br&gt;━━━ Trunk 802.1Q (VLAN dati untagged + VLAN 2 fonia tagged)&lt;br&gt;- - - da verificare / non confermato" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacing=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="280" height="100" as="geometry" />
        </mxCell>

        <mxCell id="note" value="&lt;b&gt;Confermato dall'utente 17/07/2026&lt;/b&gt;&lt;br&gt;Il QNAP QSW-1208-8c non e' piu' (se mai lo e' stato in modo stabile) un hop intermedio sulla dorsale: dallo switch 54 porte partono due patch in fibra separate, una diretta verso lo switch 30 porte (dorsale) e una verso il QNAP, che resta un ramo a parte per NAS e postazioni a 10 Gbps.&lt;br&gt;&lt;br&gt;&lt;b&gt;Aperto&lt;/b&gt;&lt;br&gt;Porta 6 del 54HP: PVID 2 come la porta 8, ruolo non ancora chiarito (NET-008/TEL-002, GAP-TBC #102/#103).&lt;br&gt;I due telefoni IP del 30HP non risultano visibili: causa non isolata, non chiaro se e' un sintomo pre-esistente o comparso con questo collegamento diretto." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#b7950b;align=left;spacing=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="30" y="170" width="280" height="220" as="geometry" />
        </mxCell>

        <mxCell id="internet" value="INTERNET" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="560" y="60" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="router" value="ROUTER VIANOVA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="550" y="160" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="firewall" value="FIREWALL ZYXEL USG FLEX 500&#10;Porta 33 switch54 — 1 Gbps rame (collo di bottiglia)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="250" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="switch54" value="SWITCH ZYXEL XGS2220-54HP (Piano 2) — Nebula managed&#10;Porta 33: uplink firewall&#10;Porta 8: DHCP+gateway fonia Vianova, PVID 2, untagged (FW-012, confermato)&#10;Porta 6: PVID 2 come porta 8 — ruolo da chiarire (aperto)&#10;Porta 52: dorsale diretta verso 30HP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="440" y="360" width="400" height="100" as="geometry" />
        </mxCell>

        <mxCell id="qnap" value="SWITCH QNAP QSW-1208-8c&#10;unmanaged L2, 10 GbE&#10;ramo separato, non piu' inline sulla dorsale" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="920" y="380" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="nas" value="NAS Fleet&#10;HERO .169 · INTRA .168 · INTRA2 .177 (10GbE) · INTRA3 .172 · DOC .170" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="900" y="490" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ws10g" value="5 postazioni endpoint a 10 Gbps&#10;(incl. workstation dedicata gia' nota)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="900" y="570" width="280" height="55" as="geometry" />
