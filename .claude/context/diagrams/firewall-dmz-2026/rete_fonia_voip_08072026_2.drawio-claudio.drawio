        <mxCell id="vlanplan" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eafaf1;strokeColor=#1e8449;align=left;spacing=8;fontSize=10" value="&lt;b&gt;PIANO VLAN&lt;/b&gt;&lt;br&gt;VLAN 1 (nativa) — Dati — 10.61.x.x — gw firewall lan1&lt;br&gt;&lt;b&gt;VLAN 100 — Fonia — 10.61.100.0/24 — gw 10.61.100.1 (FLEX 500)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;PBX: CLOUD&lt;/b&gt; → i telefoni escono via WAN&lt;br&gt;DHCP VLAN 100 sul firewall (DNS corretto, Option 66 solo se richiesta dal provider)" vertex="1">
