(rete intermedia raggiunta via lan1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f8ff;strokeColor=#6c8ebf;align=left;fontSize=9;spacingLeft=8;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="50" y="630" width="400" height="80" as="geometry"/></mxCell><mxCell id="rt2" value="&lt;b&gt;Route 3:&lt;/b&gt;  10.61.200.0/24  →  gw 10.61.100.1
