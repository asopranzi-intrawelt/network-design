# --- Sistema di progetto portabile: livello privato e ignorato ---

# Livello privato e verboso
_notes/

# Override personali e permessi personali
CLAUDE.local.md
.claude/settings.local.json

# Estratti temporanei dei .docx (cartelle scratch)
_notes/.tmp-docx-*/
.tmp-docx-*/

# Documenti Word grezzi (binari)
*.docx
*.doc

# Ambiente materializzato
.venv/
__pycache__/
*.pyc
node_modules/

# --- Output script Proxmox: artefatti generati, potenzialmente sensibili ---
# Contengono dettagli completi dell'infrastruttura (IP, nomi VM, configurazioni di rete).
# Non si versionano: si generano a runtime e si usano come contesto nella sessione.
output/

# --- Credenziali locali: mai nel repository (vedi ADR-007/008) ---
# Backup umano dei segreti (token API Proxmox, ecc.). La copia operativa
# vive nelle variabili d'ambiente utente; questo file non lo legge nessuno
# script e le regole deny della sessione ne bloccano la lettura all'agente.
.env
.env.*
