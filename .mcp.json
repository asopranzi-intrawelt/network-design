{
  "mcpServers": {
    "proxmox": {
      "command": "uvx",
      "args": ["proxmox-mcp"],
      "env": {
        "PROXMOX_URL": "${PROXMOX_URL}",
        "PROXMOX_TOKEN_NAME": "${PROXMOX_TOKEN_NAME}",
        "PROXMOX_TOKEN_VALUE": "${PROXMOX_TOKEN_VALUE}",
        "PROXMOX_VERIFY_SSL": "false",
        "PROXMOX_ALLOW_DANGER": "true"
      }
    }
  }
}
